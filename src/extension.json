{
  "name": "ADTMainpage",
  "version": "2.0.1",
  "author": "[[User:Mr._Arceni|Mr. Arceni]]",
  "type": "other",
  "description": "An extension for the Adventure Time wiki's main page using the Citizen skin.",
  "license-name": "CC-BY-NC-SA-4.0",
  "requires": {
    "MediaWiki": ">= 1.41.0",
    "skins": {
      "Citizen": ">= 2.40.2"
    }
  },
  "ResourceModules": {
    "ext.adt.mainpage": {
      "localBasePath": "resources",
      "remoteExtPath": "ADTMainpage/resources",
      "styles": [
        "styles.css"
      ],
      "scripts": [
        "script.js"
      ],
      "dependencies": [
        "mediawiki.util",
        "mediawiki.api",
        "jquery"
      ],
      "targets": [ "desktop", "mobile" ]
    }
  },
  "APIModules": {
    "adtserverstatus": {
      "class": "MediaWiki\\Extension\\ADTMainpage\\ApiServerStatus",
      "services": [
        "HttpRequestFactory",
        "MainWANObjectCache"
      ]
    }
  },
  "Hooks": {
    "BeforePageDisplay": "ADTMainPageHooks::onBeforePageDisplay"
  },
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\ADTMainpage\\": "includes/"
  },
  "AutoloadClasses": {
    "ADTMainPageHooks": "includes/ADTMainPageHooks.php",
    "ApiServerStatus": "includes/ApiServerStatus.php"
  },
  "manifest_version": 2
}